vars {
  baseUrl: http://localhost:8000
  email: kyrylo@photo-feed.local
  password: pass1234
}

docs {
  ## photo-feed API

  All requests use HttpOnly auth cookies — log in once via `auth/login` and the
  cookies stick for the rest of the requests in this run.

  Default credentials point at the seeded `kyrylo` user. To use a different demo
  user, override `email` / `password` in the collection or environment vars.
}
