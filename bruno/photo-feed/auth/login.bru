meta {
  name: login
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/auth/login/
  body: json
  auth: none
}

body:json {
  {
    "email": "{{email}}",
    "password": "{{password}}"
  }
}

docs {
  Logs in the demo `kyrylo` user by default. Sets HttpOnly access_token +
  refresh_token cookies; subsequent requests in this collection inherit them.
}
